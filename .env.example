PORT=8080
MAX_UPLOAD_BYTES=2147483648
# MAX_CONCURRENT_JOBS defaults to CPU count
# MAX_CONCURRENT_JOBS=4
JOB_TIMEOUT_MS=600000
# Comma-separated list; required in production
ALLOWED_ORIGINS=http://localhost:3000
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
FFMPEG_EXTRA_ARGS=
LOG_LEVEL=INFO

# --- Stateful API (PR #1+) --------------------------------------------------
# Postgres for production (host running compose). Empty = stateful API disabled
# (legacy /v1/normalize + /v1/segment still work).
DATABASE_URL=postgresql+asyncpg://videonizer:CHANGEME@127.0.0.1:5432/videonizer
# DATA_DIR holds tmp uploads + (compose-managed) pg/minio data dirs:
#   /appdata/storage/videonizer/{pg,minio,tmp}
DATA_DIR=/appdata/storage/videonizer
TEMP_DIR=/appdata/storage/videonizer/tmp

# --- MinIO / S3-compatible object storage -----------------------------------
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=videonizer
S3_ACCESS_KEY=CHANGEME
S3_SECRET_KEY=CHANGEME
# MinIO requires path-style addressing.
S3_FORCE_PATH_STYLE=true

# --- Compose secrets (used by docker-compose.yml only) ----------------------
POSTGRES_PASSWORD=CHANGEME
MINIO_ROOT_USER=CHANGEME
MINIO_ROOT_PASSWORD=CHANGEME

# --- Auto migration ---------------------------------------------------------
# Run alembic upgrade head on startup. Disable in multi-replica deployments.
AUTO_MIGRATE=true
